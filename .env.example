# MongoDB connection string.
# Leave empty / localhost during local dev to auto-use an in-memory MongoDB
# (requires internet access to download the Mongo binary the first time).
# Set to your real Atlas/production URI for staging & production.
MONGO_URI=

# Secret used to sign JWT auth tokens. Use a long random string in production.
JWT_SECRET=

# Server port (defaults to 5000 if not set)
PORT=5000

# development | production
# In production, the in-memory MongoDB fallback is disabled and MONGO_URI is required.
NODE_ENV=development

# Google OAuth Client ID (must match EXPO_PUBLIC_GOOGLE_CLIENT_ID used in the frontend)
# Used to verify Google Sign-In ID tokens on POST /api/v1/auth/google
GOOGLE_CLIENT_ID=

# Google OAuth Client Secret (Web application type client).
# Needed to exchange the calendar-scoped authorization code for
# access_token/refresh_token on POST /api/v1/auth/google/calendar,
# and to refresh expired access tokens server-side.
GOOGLE_CLIENT_SECRET=

# Redirect URI registered on the Google OAuth client, used during the
# calendar-connect authorization-code exchange. Must match exactly what
# the frontend passes when it kicks off that flow.
GOOGLE_REDIRECT_URI=

# Gemini API key (https://aistudio.google.com/apikey).
# Powers POST /api/process-input (intent classification/entity extraction)
# and GET /api/dashboard/daily-briefing (natural-language summary).
GEMINI_API_KEY=

# Gemini model to use (defaults to gemini-2.5-flash if unset).
GEMINI_MODEL=gemini-2.5-flash

# Optional: Expo Access Token for authenticated push notification sends via
# the Expo Push API. If unset, notifications are logged to the server console
# instead of delivered to a device (fine for local dev).
EXPO_ACCESS_TOKEN=
